# MyFoodLoad 환경변수 설정 파일
# 이 파일을 복사하여 .env 로 이름 변경 후 실제 키를 입력하세요.
# .env 파일은 .gitignore에 의해 커밋에서 제외됩니다.

# ── 필수 (미설정 시 서버 기동 실패) ─────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_must_be_at_least_32_bytes
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── 필수 (API 기능 동작 불가) ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
KAKAO_API_KEY=your_kakao_rest_api_key_here
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key_here

# ── 선택 (기본값 존재) ──────────────────────────────────────────────────────
# DATABASE_URL=jdbc:postgresql://localhost:5432/myfoodload
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=postgres
